{
  "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
  "tasks.max": "1",
  "topics": "idpay-transaction",
  "connection.url": "jdbc:postgresql://${env:POSTGRES_HOST}:5432/postgres?sslmode=require",
  "connection.user": "idpaydbadmin",
  "connection.password": "${env:POSTGRES_PASSWORD}",

  "insert.mode": "update",
  "table.name.format": "idpay.transaction_outbox",

  "pk.mode": "record_value",
  "pk.fields": "transaction_id,event_type",

  "fields.whitelist": "published",

  "transforms": "setPublishedTrue",
  "transforms.setPublishedTrue.type": "org.apache.kafka.connect.transforms.InsertField$Value",
  "transforms.setPublishedTrue.boolean.field": "published",
  "transforms.setPublishedTrue.boolean.value": "true"
}