.create table CitizenMetricsSnapshot (
    snapshot_date: datetime,
    fiscal_code: string,
    first_active_date: datetime,
    is_active_today: bool,
    last_activity_date: datetime
)

.create table CitizenMetricsAggregate (
    metric_date: datetime,
    total_unique_active_alltime: long,
    active_in_last_30_days: long,
    active_today: long,
    snapshot_timestamp: datetime
)
