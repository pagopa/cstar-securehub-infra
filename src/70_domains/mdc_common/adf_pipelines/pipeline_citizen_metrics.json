{
  "name": "pl_citizen_metrics_daily",
  "properties": {
    "description": "Extract distinct active citizens from Cosmos and load metrics to ADX",
    "activities": [
      {
        "name": "Extract_Citizen_Metrics",
        "type": "Copy",
        "inputs": [
          {
            "referenceName": "ds_citizen_consents",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_citizen_metrics",
            "type": "DatasetReference"
          }
        ],
        "typeProperties": {
          "source": {
            "type": "CosmosDbMongoDbApiSource",
            "query": "{\n  \"$group\": {\n    \"_id\": \"$fiscalCode\"\n  }\n}\n{\n  \"$count\": \"total_active_citizens\"\n}\n{\n  \"$project\": {\n    \"_id\": 0,\n    \"metric_date\": {\n      \"$literal\": \"@{utcnow('yyyy-MM-dd')}\"\n    },\n    \"total_active_citizens\": \"$total_active_citizens\",\n    \"ingestion_time\": {\n      \"$literal\": \"@{utcnow('yyyy-MM-ddTHH:mm:ssZ')}\"\n    },\n    \"updated_timestamp\": {\n      \"$literal\": \"@{utcnow('yyyy-MM-ddTHH:mm:ssZ')}\"\n    }\n  }\n}"
          }
        }
      }
    ]
  }
}