{
  "name": "citizen_metrics_daily",
  "properties": {
    "activities": [
      {
        "name": "Copy unique citizens snapshot",
        "type": "Copy",
        "typeProperties": {
          "source": {
            "type": "CosmosDbMongoDbApiSource",
            "batchSize": 1000,
            "query": "[\n  {\n    \"$match\": {\n      \"fiscalCode\": { \"$exists\": true }\n    }\n  },\n  {\n    \"$project\": {\n      \"_id\": 0,\n      \"fiscal_code\": \"$fiscalCode\",\n      \"snapshot_date\": { \"$literal\": \"@{utcnow('yyyy-MM-dd')}\" },\n      \"first_active_date\": { \"$literal\": \"@{utcnow('yyyy-MM-dd')}\" },\n      \"last_activity_date\": { \"$literal\": \"@{utcnow('yyyy-MM-dd')}\" },\n      \"is_active_today\": true\n    }\n  }\n]"
          },
          "sink": {
            "type": "AzureDataExplorerSink"
          },
          "translator": {
            "type": "TabularTranslator",
            "mappings": [
              { "source": { "path": "$['fiscal_code']" }, "sink": { "name": "fiscal_code", "type": "String" } },
              { "source": { "path": "$['first_active_date']" }, "sink": { "name": "first_active_date", "type": "DateTime" } },
              { "source": { "path": "$['last_activity_date']" }, "sink": { "name": "last_activity_date", "type": "DateTime" } },
              { "source": { "path": "$['snapshot_date']" }, "sink": { "name": "snapshot_date", "type": "DateTime" } },
              { "source": { "path": "$['is_active_today']" }, "sink": { "name": "is_active_today", "type": "Boolean" } }
            ]
          }
        },
        "inputs": [
          { "referenceName": "mdc_citizen_consents", "type": "DatasetReference" }
        ],
        "outputs": [
          { "referenceName": "mdc_citizen_metrics_snapshot", "type": "DatasetReference" }
        ]
      },
      {
        "name": "Aggregate metrics",
        "type": "AzureDataExplorerCommand",
        "dependsOn": [
          { "activity": "Copy unique citizens snapshot", "dependencyConditions": ["Succeeded"] }
        ],
        "typeProperties": {
          "command": ".set-or-append CitizenMetricsAggregate <|\n  let today = startofday(now());\n  let last_30_days = ago(30d);\n  CitizenMetricsSnapshot\n  | where snapshot_date >= startofday(now())\n  | summarize\n      total_unique_alltime = dcount(fiscal_code),\n      active_in_last_30_days = dcountif(fiscal_code, last_activity_date >= last_30_days),\n      active_today = dcountif(fiscal_code, is_active_today == true)\n  | project\n      metric_date = today,\n      total_unique_active_alltime = total_unique_alltime,\n      active_in_last_30_days = active_in_last_30_days,\n      active_today = active_today,\n      snapshot_timestamp = now()",
          "commandTimeout": "00:30:00"
        },
        "linkedServiceName": {
          "referenceName": "mdc-Kusto-mdc-ls",
          "type": "LinkedServiceReference"
        }
      }
    ]
  }
}
