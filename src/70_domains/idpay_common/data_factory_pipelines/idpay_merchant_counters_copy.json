{
    "name": "idpay_merchant_counters_copy",
    "properties": {
        "activities": [
            {
                "name": "Copy merchant counters collection",
                "type": "Copy",
                "dependsOn": [
                    {
                        "activity": "Clear merchant counters table",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "CosmosDbMongoDbApiSource",
                        "batchSize": 100
                    },
                    "sink": {
                        "type": "AzureDataExplorerSink"
                    },
                    "enableStaging": false,
                    "translator": {
                        "type": "TabularTranslator",
                        "mappings": [
                            {
                                "source": {
                                    "path": "$['_id']"
                                },
                                "sink": {
                                    "name": "_id",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['merchantId']"
                                },
                                "sink": {
                                    "name": "merchantId",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['totalProvidedCents']"
                                },
                                "sink": {
                                    "name": "totalProvidedCents",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['totalRefundedCents']"
                                },
                                "sink": {
                                    "name": "totalRefundedCents",
                                    "type": "Long"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['initiativeId']"
                                },
                                "sink": {
                                    "name": "initiativeId",
                                    "type": "Long"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['trxNumber']"
                                },
                                "sink": {
                                    "name": "trxNumber",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['refundedNumber']"
                                },
                                "sink": {
                                    "name": "refundedNumber",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['totalProvidedCents']"
                                },
                                "sink": {
                                    "name": "totalProvidedCents",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['totalRefundedCents']"
                                },
                                "sink": {
                                    "name": "totalRefundedCents",
                                    "type": "Long"
                                }
                            },
                            {
                                "source": {
                                    "path": "lastUpdatedDateTime.$date."
                                },
                                "sink": {
                                    "name": "lastUpdatedDateTimeString",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "createdAt.$date"
                                },
                                "sink": {
                                    "name": "createdAtString",
                                    "type": "String"
                                }
                            }
                        ]
                    }
                },
                "inputs": [
                    {
                        "referenceName": "cosmos_idpay_merchant_counters",
                        "type": "DatasetReference"
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "data_explorer_idpay_merchant_counters",
                        "type": "DatasetReference"
                    }
                ]
            },
            {
                "name": "Convert Date",
                "type": "AzureDataExplorerCommand",
                "dependsOn": [
                    {
                        "activity": "Copy merchant counters collection",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "command": ".set-or-replace merchant_initiative_counters<|\nmerchant_initiative_counters\n| extend \n    lastUpdatedDateTime= unixtime_milliseconds_todatetime(tolong(lastUpdatedDateTimeString)),\n    createdAt= unixtime_milliseconds_todatetime(tolong(createdAtString))",
                    "commandTimeout": "00:20:00"
                },
                "linkedServiceName": {
                    "referenceName": "idpay-Kusto-idpay-ls",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "Clear merchant counters table",
                "type": "AzureDataExplorerCommand",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "command": ".clear table merchant_initiative_counters data",
                    "commandTimeout": "00:20:00"
                },
                "linkedServiceName": {
                    "referenceName": "idpay-Kusto-idpay-ls",
                    "type": "LinkedServiceReference"
                }
            }
        ],
        "annotations": [],
        "lastPublishTime": "2025-10-08T10:38:06Z"
    },
    "type": "Microsoft.DataFactory/factories/pipelines"
}
