          "pluginVersion": "7.2.6",
          "query": "let messaggiAccettati = toscalar(\r\n    MessageVolumeSnapshot\r\n    | where $__timeFilter(window_start)\r\n    | summarize coalesce(sum(message_sent_count), 0)\r\n);\r\nlet known_origins =\r\n    MessageSnapshot\r\n    | where message_state == \"SENT\"\r\n    | summarize by origin_id;\r\nlet pagamentiCompletati = toscalar(\r\n    FinalizedMessageSnapshot\r\n    | where $__timeFilter(window_start)\r\n    | where origin_id in (known_origins)\r\n    | summarize arg_max(window_start, tpp_id) by origin_id\r\n    | summarize dcount(origin_id)\r\n);\r\nlet pspAttivi = toscalar(\r\n    FinalizedMessageSnapshot\r\n    | where $__timeFilter(window_start)\r\n    | where origin_id in (known_origins)\r\n    | summarize by tpp_id\r\n    | count\r\n);\r\nprint ['Tasso di Conversione Pagamento Totale'] =\r\n    iff(messaggiAccettati == 0 or pspAttivi == 0, 0.0,\r\n        round((100.0 * todouble(pagamentiCompletati) / todouble(messaggiAccettati)) / todouble(pspAttivi), 2))",
          "querySource": "raw",
          "queryType": "KQL",
          "rawMode": true,
          "refId": "A",
          "resultFormat": "table"
        }
