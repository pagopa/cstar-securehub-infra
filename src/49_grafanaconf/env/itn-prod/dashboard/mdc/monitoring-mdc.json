      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "OpenAI": false,
          "database": "mdc",
          "datasource": {
            "type": "grafana-azure-data-explorer-datasource",
            "uid": "${ds}"
          },
          "expression": {
            "groupBy": {
              "expressions": [],
              "type": "and"
            },
            "reduce": {
              "expressions": [],
              "type": "and"
            },
            "where": {
              "expressions": [],
              "type": "and"
            }
          },
          "pluginVersion": "7.2.2",
          "query": "let payment_map =\r\n    MessageSnapshot\r\n    | summarize arg_max(window_start, associated_payment) by origin_id;\r\n    // Nessun timeFilter per prende tutto lo storico per avere sempre associated_payment\r\n\r\nlet inviate =\r\n    MessageSnapshot\r\n    | where message_state == \"SENT\"\r\n    | where $__timeFilter(window_start)\r\n    | summarize arg_max(window_start, entity_id) by origin_id, entity_id\r\n    | project origin_id, entity_id, is_inviata = true;\r\n\r\nlet lette =\r\n    RetrievalIdVolumeSnapshot\r\n    | where $__timeFilter(window_start)\r\n    | summarize arg_max(window_start, entity_id) by origin_id, entity_id\r\n    | project origin_id, entity_id, is_letta = true;\r\n\r\nlet perfezionate =\r\n    FinalizedMessageSnapshot\r\n    | where $__timeFilter(window_start)\r\n    | summarize arg_max(window_start, tpp_id) by origin_id\r\n    | project origin_id, is_perfezionata = true;\r\n\r\n// Union di tutti gli origin_id che compaiono in almeno uno stato\r\nlet tutti =\r\n    inviate | project origin_id, entity_id\r\n    | union (lette | project origin_id, entity_id)\r\n    | summarize arg_max(origin_id, entity_id) by origin_id;\r\n\r\n// Raccolta tutte tpp per default a 0 se non ci sono valori\r\nlet tutte_le_tpp =\r\n    TppDataSnapshot\r\n    | summarize by entity_id, PSP = business_name;\r\n\r\n\r\ntutte_le_tpp\r\n| join kind=leftouter (\r\n    tutti\r\n    | join kind=leftouter payment_map on origin_id\r\n    | join kind=inner TppDataSnapshot on entity_id\r\n    | join kind=leftouter (inviate  | project origin_id, is_inviata)      on origin_id\r\n    | join kind=leftouter (lette    | project origin_id, is_letta)        on origin_id\r\n    | join kind=leftouter (perfezionate | project origin_id, is_perfezionata) on origin_id\r\n) on entity_id\r\n| summarize\r\n    ['Inv. Con Pagamento']    = dcountif(origin_id, associated_payment == true  and is_inviata == true),\r\n    ['Inv. Senza Pagamento']  = dcountif(origin_id, associated_payment == false and is_inviata == true),\r\n    ['Inviate Totale']        = dcountif(origin_id, is_inviata == true),\r\n    ['Lette Con Pagamento']   = dcountif(origin_id, associated_payment == true  and is_letta == true),\r\n    ['Lette Senza Pagamento'] = dcountif(origin_id, associated_payment == false and is_letta == true),\r\n    ['Lette Totale']          = dcountif(origin_id, is_letta == true),\r\n    ['Perf. Con Pagamento']   = dcountif(origin_id, associated_payment == true  and is_perfezionata == true),\r\n    ['Perf. Senza Pagamento'] = dcountif(origin_id, associated_payment == false and is_perfezionata == true),\r\n    ['Perfezionate Totale']   = dcountif(origin_id, is_perfezionata == true)\r\n  by PSP\r\n| order by ['Lette Totale'] desc",
          "querySource": "raw",
          "queryType": "KQL",
          "rawMode": true,
          "refId": "A",
          "resultFormat": "table"
        }
      ],
      "title": "Flusso messaggi accettati per PSP",
      "type": "table"
